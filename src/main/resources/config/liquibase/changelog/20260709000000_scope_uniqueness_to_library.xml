<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <!--
        Member.email, Book.isbn and Category.name were unique across the whole database, preventing
        two different libraries from having their own member/book/category with the same value.
        Scope these uniqueness checks to each library instead. Category doesn't have an owning
        library yet, so add one first (clearing existing test data so the new column can be
        mandatory, same approach as the earlier Library.user migration).
    -->
    <changeSet id="20260709000000-1" author="jhipster">
        <update tableName="book">
            <column name="category_id" valueComputed="NULL"/>
            <where>category_id IS NOT NULL</where>
        </update>
        <delete tableName="category"/>
    </changeSet>

    <changeSet id="20260709000000-2" author="jhipster">
        <addColumn tableName="category">
            <column name="library_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="20260709000000-3" author="jhipster">
        <addForeignKeyConstraint baseColumnNames="library_id"
                                 baseTableName="category"
                                 constraintName="fk_category__library_id"
                                 referencedColumnNames="id"
                                 referencedTableName="library"
                                 />
    </changeSet>

    <changeSet id="20260709000000-4" author="jhipster">
        <dropUniqueConstraint tableName="member" constraintName="ux_member__email"/>
        <addUniqueConstraint tableName="member" columnNames="library_id, email" constraintName="ux_member__library_id_email"/>

        <dropUniqueConstraint tableName="book" constraintName="ux_book__isbn"/>
        <addUniqueConstraint tableName="book" columnNames="library_id, isbn" constraintName="ux_book__library_id_isbn"/>

        <addUniqueConstraint tableName="category" columnNames="library_id, name" constraintName="ux_category__library_id_name"/>
    </changeSet>
</databaseChangeLog>
